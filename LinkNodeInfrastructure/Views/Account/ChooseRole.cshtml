@using Microsoft.AspNetCore.Identity
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="text-center mt-5">
    <h2>Вітаємо! Оберіть свій статус на LinkNode</h2>
    <div class="d-flex justify-content-center gap-4 mt-4">

    
        <form asp-action="SetRole" asp-controller="Account" method="post">
           
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            <input type="hidden" name="roleName" value="CLIENT" />
            <button type="submit" class="btn btn-outline-primary btn-lg p-5">
                <i class="bi bi-briefcase fs-1"></i><br />Я Клієнт
            </button>
        </form>

        
        <form asp-action="SetRole" asp-controller="Account" method="post">
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            <input type="hidden" name="roleName" value="FREELANCER" />
            <button type="submit" class="btn btn-outline-success btn-lg p-5">
                <i class="bi bi-person-workspace fs-1"></i><br />Я Фрілансер
            </button>
        </form>
    </div>
</div>