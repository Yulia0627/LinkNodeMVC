@model LinkNodeDomain.Model.Freelancer
@using System.Security.Claims

@{
    ViewData["Title"] = "Профіль фрілансера";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="d-flex justify-content-center mb-4">
                @await Html.PartialAsync("_NavigationTabs")
            </div>
            <div class="card shadow-sm border-0 custom-card">

                <div class="card-header border-0 py-4 header-dark text-center">
                    <div class="mb-3">
                        <div class="avatar-circle mx-auto bg-primary-subtle text-primary">
                            <h1 class="mb-0 fw-bold">@(Model.FreelancerNavigation?.Name?.Substring(0, 1) ?? "F")</h1>
                        </div>
                    </div>
                    <h2 class="mb-0 fw-bold text-white">
                        @Model.FreelancerNavigation?.Name @Model.FreelancerNavigation?.Surname
                    </h2>
                    <p class="text-white-50 mb-0">@Model.Category?.Category1 | @Model.EmpType?.EmpType</p>
                </div>

                <div class="card-body p-5">
                    <div class="row g-4">
                        <div class="col-md-8">
                            <div class="mb-5">
                                <h5 class="fw-bold border-bottom pb-2 mb-3">Локація</h5>
                                <p class="text-dark fs-5">
                                    <i class="bi bi-geo-alt me-2 text-danger"></i>
                                    @Model.FreelancerNavigation?.Country
                                </p>
                            </div>

                            <div>
                                <h5 class="fw-bold border-bottom pb-2 mb-3">Про себе</h5>
                                <p class="text-dark fs-5" style="line-height: 1.6;">
                                    @(string.IsNullOrEmpty(Model.Description) ? "Опис відсутній" : Model.Description)
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4 border-start">
                            <div class="p-3 bg-light rounded-3 text-center mb-3 shadow-sm border">
                                <h6 class="text-muted small text-uppercase">Погодинна ставка</h6>
                                <h2 class="text-success fw-bold mb-0">@Model.HourlyRate.ToString("C0")</h2>
                                <small class="text-muted">за годину</small>
                            </div>

                           
                            @if (User.Identity.IsAuthenticated)
                            {
                                var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                                if (currentUserId == Model.Id.ToString())
                                {
                                    <div class="mt-3">
                                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100 shadow-sm">
                                            <i class="bi bi-pencil-square me-2"></i>Редагувати профіль
                                        </a>
                                    </div>
                                }
                            }
                        </div>

                        <div class="col-12 mt-5">
                            <h5 class="fw-bold border-bottom pb-2 mb-3">Статистика поданих пропозицій</h5>
                            <div class="p-3 bg-white rounded-3 shadow-sm border">
                                <div id="freelancerActivityChart" style="width: 100%; height: 300px;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    .custom-card {
        border-radius: 15px;
        overflow: hidden;
    }

    .header-dark {
        background: linear-gradient(135deg, #2c3e50 0%, #1a252f 100%);
    }

    .avatar-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 4px solid rgba(255,255,255,0.2);
        background-color: white !important;
    }

    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', {'packages':['corechart']});
        google.charts.setOnLoadCallback(drawChart);

        function drawChart() {
            const freelancerId = @Model.Id;

            fetch(`/api/stats/freelancer-proposals-activity?freelancerId=${freelancerId}`)
                .then(response => response.json())
                .then(data => {
                    var chartData = new google.visualization.DataTable();
                    chartData.addColumn('string', 'Місяць');
                    chartData.addColumn('number', 'Пропозиції');

                    data.forEach(item => {
                        chartData.addRow([item.month + '/' + item.year, item.proposalsCount]);
                    });

                    var options = {
                        legend: { position: 'none' },
                        colors: ['#2c3e50'],
                        hAxis: { textStyle: { color: '#6c757d', fontSize: 11 } },
                        vAxis: { minValue: 0, gridlines: { color: '#f0f0f0' }, format: '0' },
                        chartArea: { width: '90%', height: '80%' },
                        animation: { startup: true, duration: 800, easing: 'out' }
                    };

                    var chart = new google.visualization.ColumnChart(document.getElementById('freelancerActivityChart'));
                    chart.draw(chartData, options);
                })
                .catch(error => console.error('Помилка завантаження статистики:', error));
        }
    </script>
}