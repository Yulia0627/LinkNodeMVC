@model IEnumerable<LinkNodeDomain.Model.Freelancer>

@{
    ViewData["Title"] = "Керування фрілансерами";
}

@await Html.PartialAsync("_NavigationTabs")

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <h1 class="h3">Керування фрілансерами</h1>

    <form asp-action="ForAdmin" method="get" class="d-flex gap-2">
        <div class="input-group input-group-sm">
            <input type="number" name="searchId" min="0" class="form-control"
                   placeholder="Пошук за ID..." value="@Context.Request.Query["searchId"]" />
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Знайти
            </button>
        </div>
        <a asp-action="ForAdmin" class="btn btn-outline-secondary btn-sm d-flex align-items-center">Скинути</a>
    </form>
</div>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-light">
        <tr>
            <th style="width: 80px;">ID</th>
            <th>Фрілансер</th>
            <th>Категорія</th>
            <th style="width: 150px;">Статус</th>
            <th style="width: 200px;">Дія</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">@item.Id</td>
                <td>
                    <div>
                        <span class="fw-bold">@item.FreelancerNavigation?.Name @item.FreelancerNavigation?.Surname</span>
                        <br />
                        <small class="text-muted">@item.FreelancerNavigation?.Email</small>
                    </div>
                </td>
                <td>
                    <span class="badge bg-info-subtle text-info border border-info-subtle">
                        @item.Category?.Category1
                    </span>
                </td>
                <td>
                    @if (item.FreelancerNavigation?.IsActive == true)
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3">Активний</span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3">Заблокований</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2">
                        
                        <form asp-controller="Users" asp-action="ToggleBlock" asp-route-id="@item.Id"
                              asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                              method="post" class="m-0">

                            @if (item.FreelancerNavigation?.IsActive == true)
                            {
                                <button type="submit" class="btn btn-sm btn-warning d-flex align-items-center gap-1">
                                    <i class="bi bi-slash-circle"></i> Блокувати
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-success d-flex align-items-center gap-1">
                                    <i class="bi bi-check-circle"></i> Розблокувати
                                </button>
                            }
                        </form>

     
                    </div>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">
                    Фрілансера з таким ідентифікатором не знайдено.
                </td>
            </tr>
        }
    </tbody>
</table>