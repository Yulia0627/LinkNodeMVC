@model LinkNodeDomain.Model.Interview

@{
    ViewData["Title"] = "Запрошення на інтерв'ю";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 text-center"><i class="bi bi-calendar-event me-2"></i>Запрошення на інтерв'ю</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>
                        <input type="hidden" asp-for="PropId" />

                        <div class="mb-3">
                            <label asp-for="DateTime" class="form-label fw-bold" type="datetime-local" value="@Model?.DateTime.ToString("yyyy-MM-ddTHH:mm")">Дата та час зустрічі</label>
                            <div class="input-group">
                                <input asp-for="DateTime" class="form-control shadow-none" type="datetime-local" />
                            </div>
                            <span asp-validation-for="DateTime" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Reference" class="form-label fw-bold">Посилання</label>
                            <input asp-for="Reference" class="form-control shadow-none" placeholder="https://zoom.us/j/..." />
                            <span asp-validation-for="Reference" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="InterviewRound" class="form-label fw-bold">Етап інтерв'ю</label>
                            <input asp-for="InterviewRound" class="form-control shadow-none" placeholder="Наприклад: Технічне або HR" />
                            <span asp-validation-for="InterviewRound" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-check-circle me-1"></i> Створити запрошення
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted mt-2">Повернутися до списку</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Додатковий легкий тюнінг */
    body {
        background-color: #f8f9fa;
    }
    .card {
        border-radius: 12px;
        overflow: hidden;
    }
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25 red border-color: rgba(13, 110, 253, 0.1);
    }
    .btn-primary {
        border-radius: 8px;
        transition: transform 0.1s ease;
    }
    .btn-primary:active {
        transform: scale(0.98);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}