@model LinkNodeDomain.Model.Interview

@{
    ViewData["Title"] = "Details";
}

<hr />
<div class="container mt-5">
    <h4 class="mb-4"><i class="bi bi-clock-history me-2"></i>Історія змін статусу</h4>

    <div class="position-relative">
        <div class="position-absolute start-0 h-100 border-start border-2 border-primary ms-3"></div>

        @foreach (var story in Model.CallStatusStories)
        {
            <div class="mb-4 position-relative ps-5">
                <div class="position-absolute start-0 translate-middle-x bg-primary rounded-circle ms-3"
                     style="width: 15px; height: 15px; margin-top: 10px; z-index: 1;"></div>

                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-secondary">@story.ChangedDate.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <p class="mb-0">
                            Статус змінено з
                            <span class="text-danger fw-bold">"@story.OldStatus?.Status"</span>
                            на
                            <span class="text-success fw-bold">"@story.NewStatus?.Status"</span>
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (!Model.CallStatusStories.Any())
        {
            <p class="text-muted ps-5">Історія змін поки що порожня.</p>
        }
    </div>
</div>

<style>
    
    .border-primary { border-color: #0d6efd !important; opacity: 0.3; }
    .card { transition: 0.3s; }
    .card:hover { transform: scale(1.01); }
</style>