@model LinkNodeDomain.Model.Interview

@{
    ViewData["Title"] = "Зміни в інтерв'ю";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 custom-card">

                <div class="card-header border-0 py-3 text-center header-dark">
                    <h4 class="mb-0 fw-bold">Запрошення на інтерв'ю</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PropId" />
                        <input type="hidden" asp-for="CreatedDate" />
                        <input type="hidden" asp-for="IntroStatusId" /> <div class="mb-3">
                            <label asp-for="DateTime" class="form-label fw-bold">Дата та час зустрічі</label>
                            <input asp-for="DateTime" class="form-control custom-input" type="datetime-local" />
                            <span asp-validation-for="DateTime" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Reference" class="form-label fw-bold">Посилання</label>
                            <input asp-for="Reference" class="form-control custom-input" placeholder="https://zoom.us/j/..." />
                            <span asp-validation-for="Reference" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="InterviewRound" class="form-label fw-bold">Етап інтерв'ю</label>
                            <input asp-for="InterviewRound" class="form-control custom-input" />
                            <span asp-validation-for="InterviewRound" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark btn-lg py-2 fs-5 custom-btn">
                                Зберегти зміни
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted mt-2 text-decoration-none small">
                                Скасувати та повернутися
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Картка з закругленими кутами */
    .custom-card {
        border-radius: 10px;
        overflow: hidden;
    }

    /* Стиль заголовка (темно-синій/сірий як на фото) */
    .header-dark {
        background-color: #2c3e50; /* Колір заголовка зі скріншоту */
        color: #ffffff;
    }

    /* Стиль полів вводу */
    .custom-input {
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 10px 12px;
        background-color: #ffffff;
    }

        .custom-input:focus {
            border-color: #2c3e50;
            box-shadow: none;
        }

    /* Кнопка "Створити/Зберегти" */
    .custom-btn {
        background-color: #2c3e50;
        border: none;
        border-radius: 8px;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .custom-btn:hover {
            background-color: #1a252f;
        }

    /* Шрифти лейблів */
    .form-label {
        color: #212529;
        margin-bottom: 8px;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
