@model IEnumerable<LinkNodeDomain.Model.Interview>

@{
    ViewData["Title"] = "Список інтерв'ю";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-dark">Календар інтерв'ю</h1>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0 position-relative" style="border-radius: 15px;">
                    <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge rounded-pill @(item.IntroStatusId == 1 ? "bg-primary" : "bg-success") px-3">
                            @Html.DisplayFor(modelItem => item.IntroStatus.Status)
                        </span>
                    </div>

                    <div class="card-body p-4">
                        <div class="text-muted small mb-2">
                            <i class="bi bi-clock me-1"></i> Створено: @item.CreatedDate.ToString("dd.MM.yyyy")
                        </div>

                        <h5 class="card-title fw-bold mb-3">
                            @Html.DisplayFor(modelItem => item.InterviewRound) раунд
                        </h5>

                        <div class="d-flex align-items-center mb-2">
                            <div class="bg-light p-2 rounded-circle me-3">
                                <i class="bi bi-calendar-event text-primary fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-bold">@item.DateTime.ToString("dd MMMM, yyyy")</div>
                                <div class="text-muted">о @item.DateTime.ToString("HH:mm")</div>
                            </div>
                        </div>

                        <hr class="my-3 opacity-25">

                        <p class="card-text small text-secondary">
                            <strong>Пропозиція:</strong> @Html.DisplayFor(modelItem => item.Prop.Description)
                        </p>

                        @if (item.IntroStatusId != 5)
                        {
                            <a href="@item.Reference" class="btn btn-outline-primary w-100">
                                Приєднатися до зустрічі
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary w-100" disabled>
                                Зустріч скасована
                            </button>
                        }
                    </div>

                    <div class="card-footer bg-white border-0 p-3 d-flex justify-content-around">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-decoration-none text-primary small">
                            <i class="bi bi-pencil-square"></i> Редагувати
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-info small mx-3">
                            <i class="bi bi-eye"></i> Деталі
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-decoration-none text-danger small">
                            <i class="bi bi-trash"></i> Скасувати
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .badge {
        font-weight: 500;
        letter-spacing: 0.5px;
    }
</style>