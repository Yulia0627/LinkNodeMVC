@model IEnumerable<LinkNodeDomain.Model.Invite>

@{
    ViewData["Title"] = "Список запрошень";
}
@await Html.PartialAsync("_NavigationTabs")

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-dark">📩 Список запрошень</h1>
        <span class="badge bg-primary rounded-pill">Всього: @Model.Count()</span>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center bg-white rounded-3">
            <i class="bi bi-envelope-x text-muted" style="font-size: 3rem;"></i>
            <h4 class="text-muted mt-3">Запрошень поки немає</h4>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 mb-3">
                    <div class="card border-0 shadow-sm invite-card overflow-hidden transition-hover">
                        <div class="row g-0">
                            
                            <div class="col-md-1 bg-primary d-none d-md-flex align-items-center justify-content-center text-white">
                                <i class="bi bi-send-fill fs-3"></i>
                            </div>

                            <div class="col-md-11">
                                <div class="card-body p-4">
                                    <div class="row align-items-center">
                                       
                                        <div class="col-md-5">
                                            <h5 class="fw-bold mb-1 text-primary">@item.Vacancy?.Title</h5>
                                            <p class="text-muted fw-semibold mb-1 small">
                                                <i class="bi bi-building"></i> @item.Vacancy?.Client?.ClientNavigation?.UserName
                                            </p>
                                            <p class="text-muted small mb-0 text-truncate">
                                                @item.Vacancy?.Description
                                            </p>
                                        </div>

                                        
                                        @if (User.IsInRole("client"))
                                        {
                                            <div class="col-md-3 border-start">
                                                <div class="d-flex flex-column justify-content-center h-100 ps-md-3">
                                                    <a asp-controller="Freelancers" asp-action="Details" asp-route-id="@item.FreelancerId"
                                                    class="btn btn-sm btn-outline-secondary px-3 rounded-pill w-auto">
                                                        <i class="bi bi-person-badge"></i> Переглянути фрілансера
                                                    </a>
                                                </div>
                                            </div>
                                        }

                                        
                                        <div class="col-md-2 text-center">
                                            @{
                                                var statusName = item.Status?.InviteStatus1;
                                                var statusClass = statusName == "Прийнято" || statusName == "Підтверджено" ? "bg-success" :
                                                statusName == "Відхилено" ? "bg-danger" :
                                                "bg-warning text-dark";

                                                var statusIcon = statusName == "Прийнято" || statusName == "Підтверджено" ? "bi-check-circle-fill" :
                                                statusName == "Відхилено" ? "bi-x-circle-fill" :
                                                "bi-clock-fill";
                                            }
                                            <span class="badge rounded-pill @statusClass px-3 py-2 shadow-sm">
                                                <i class="bi @statusIcon me-1"></i> @(statusName ?? "Очікується")
                                            </span>
                                        </div>

                                        
                                        <div class="col-md-2">
                                            <div class="d-flex flex-column gap-2">
                                                
                                                @if (item.StatusId == 3 && User.IsInRole("freelancer"))
                                                {
                                                    
                                                    <a asp-controller="Proposals" asp-action="Create" asp-route-vacancyId="@item.VacancyId"
                                                       class="btn btn-success btn-sm px-3 rounded-pill fw-bold shadow-sm">
                                                        <i class="bi bi-file-earmark-plus me-1"></i> Податися
                                                    </a>

                                                    
                                                    <form asp-action="Reject" asp-route-id="@item.Id" method="post"
                                                          onsubmit="return confirm('Ви впевнені, що хочете відхилити це запрошення?');">
                                                        <button type="submit" class="btn btn-outline-danger btn-sm px-3 rounded-pill w-100 fw-bold">
                                                            <i class="bi bi-x-circle me-1"></i> Відхилити
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    
                                                    <a asp-controller="Vacancies" asp-action="Details" asp-route-id="@item.VacancyId"
                                                       class="btn btn-primary btn-sm px-3 rounded-pill fw-bold shadow-sm">
                                                        Деталі вакансії
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
        }

    .text-truncate {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>