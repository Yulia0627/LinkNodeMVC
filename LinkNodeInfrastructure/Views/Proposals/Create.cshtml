@model LinkNodeDomain.Model.Proposal

@{
    ViewData["Title"] = "Відправлення пропозиції";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">

                <div class="card-header py-3 border-0 text-center" style="background-color: #34495e;">
                    <h4 class="mb-0 fw-bold text-white">Ваша пропозиція</h4>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="VacancyId" />

                        <div class="text-center mb-4">
                            <i class="bi bi-rocket-takeoff text-primary" style="font-size: 2.5rem;"></i>
                            <p class="text-muted small mt-2">Вкажіть вашу ціну та розкажіть замовнику, чому ви — найкращий кандидат</p>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Price" class="form-label fw-bold small text-dark">Вартість виконання (₴)</label>
                            <div class="input-group shadow-sm-hover">
                                <span class="input-group-text bg-light border-1 fw-bold text-muted">₴</span>
                                <input asp-for="Price" class="form-control bg-light border-1 py-2" placeholder="Наприклад: 5000" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold small text-dark">Супровідний лист</label>
                            <div class="input-group shadow-sm-hover">
                                <span class="input-group-text bg-light border-1"><i class="bi bi-chat-left-text"></i></span>
                                <textarea asp-for="Description" class="form-control bg-light border-1 py-2" rows="5"
                                          placeholder="Опишіть ваш досвід та як ви плануєте вирішити завдання..."></textarea>
                            </div>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn py-2 fw-bold text-white shadow-sm" style="background-color: #34495e;">
                                Надіслати відгук
                            </button>
                        </div>

                        <div class="text-center">
                            <a asp-action="Index" asp-controller="Vacancies" class="text-muted small text-decoration-underline">
                                <i class="bi bi-arrow-left"></i> Назад до вакансій
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
        color: #34495e;
        border: 1px solid #dee2e6;
    }

    .form-control {
        border-radius: 0 8px 8px 0 !important;
        border: 1px solid #dee2e6;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #34495e;
            box-shadow: none;
        }

    .card {
        border-radius: 12px !important;
    }

    .btn:hover {
        filter: brightness(1.1);
        transition: 0.3s;
    }

    textarea.form-control {
        resize: none;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}