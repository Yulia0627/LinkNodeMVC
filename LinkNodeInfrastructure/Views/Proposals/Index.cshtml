@model IEnumerable<LinkNodeDomain.Model.Proposal>

@{
    ViewData["Title"] = "Пропозиції";
}

<div class="container mt-5">
    <div class="d-flex justify-content-center mb-4">
        @await Html.PartialAsync("_NavigationTabs")
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-dark">@(User.IsInRole("Client") ? "Отримані пропозиції" : "Мої пропозиції")</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 15px;">
            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
            <h4 class="text-muted mt-3">Поки що немає жодної пропозиції</h4>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    
                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                        <div class="card h-100 shadow-sm border-0 hover-card overflow-hidden" style="border-radius: 15px;">

                            <div class="card-body p-4 d-flex flex-column">

                              
                                <div class="text-muted small mb-2 d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-calendar3 me-1"></i> @item.CreatedDate.ToString("dd.MM.yyyy")</span>
                                    <span class="text-success fw-bold fs-5">@item.Price.ToString("C0")</span>
                                </div>

                               
                                <h5 class="card-title fw-bold mb-2">
                                    @(item.Vacancy?.Title ?? "Пропозиція")
                                </h5>

                                @if (User.IsInRole("Client"))
                                {
                                    <p class="text-primary small mb-3">
                                        <i class="bi bi-person-circle"></i> Від: Фрілансер #@item.FreelancerId
                                    </p>
                                }

                                <p class="card-text text-secondary mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; min-height: 4.5em;">
                                    @item.Description
                                </p>

                                
                                <div class="mt-auto" onclick="event.stopPropagation();">
                                    @if (User.IsInRole("Client"))
                                    {
                                        <object>
                                            
                                            <a asp-controller="Interviews" asp-action="Create" asp-route-proposalId="@item.Id"
                                               class="btn btn-primary w-100 rounded-pill shadow-sm" style="position: relative; z-index: 10;">
                                                <i class="bi bi-calendar-plus me-2"></i> Запросити на інтерв'ю
                                            </a>
                                        </object>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
        }

    .nav-tabs {
        border-bottom: 2px solid #dee2e6;
    }

        .nav-tabs .nav-link {
            border: none;
            color: #6c757d;
            padding: 10px 20px;
        }

            .nav-tabs .nav-link.active {
                color: #0d6efd !important;
                background: none;
            }
</style>