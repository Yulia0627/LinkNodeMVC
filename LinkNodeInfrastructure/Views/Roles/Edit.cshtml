@using Microsoft.AspNetCore.Identity
@model LinkNodeInfrastructure.ViewModels.ChangeRoleViewModel

@{
    ViewData["Title"] = "Редагування прав";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h2 class="h5 mb-0">Зміна ролей для користувача: <strong>@Model.UserEmail</strong></h2>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" name="userId" value="@Model.UserId" />

                <p class="text-muted mb-3">Оберіть ролі, які будуть призначені цьому користувачу:</p>

                <div class="form-group mb-4">
                    @foreach (IdentityRole role in Model.AllRoles)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="roles" value="@role.Name" id="role_@role.Id"
                                   @(Model.UserRoles.Contains(role.Name) ? "checked=\"checked\"" : "") />
                            <label class="form-check-label" for="role_@role.Id">
                                @role.Name
                            </label>
                        </div>
                    }
                </div>

                <div class="border-top pt-3">
                    <button type="submit" class="btn btn-success px-4">Зберегти зміни</button>
                    <a asp-action="UserList" class="btn btn-outline-secondary px-4">Скасувати</a>
                </div>
            </form>
        </div>
    </div>
</div>

