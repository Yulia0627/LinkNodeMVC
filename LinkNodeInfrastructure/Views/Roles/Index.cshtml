@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Керування ролями";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Список ролей системи</h2>
        <div>
            <a asp-action="Create" class="btn btn-success">Додати нову роль</a>
            <a asp-action="UserList" class="btn btn-outline-primary">Список користувачів</a>
        </div>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Назва ролі</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="2" class="text-center text-muted">Ролей поки не створено. Натисніть "Додати нову роль".</td>
                </tr>
            }
            @foreach (var role in Model)
            {
                <tr>
                    <td class="align-middle">
                        <strong>@role.Name</strong>
                    </td>
                    <td class="text-end">
                        <form asp-action="Delete" asp-route-id="@role.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цю роль?');">
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Видалити
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

