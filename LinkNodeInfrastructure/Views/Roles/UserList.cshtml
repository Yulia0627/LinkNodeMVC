@model IEnumerable<LinkNodeDomain.Model.User>

@{
    ViewData["Title"] = "Керування доступом";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Список користувачів системи</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад до ролей</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Email користувача</th>
                        <th class="text-end pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle">
                                @user.Email
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <a class="btn btn-sm btn-primary"
                                   asp-action="Edit"
                                   asp-route-userid="@user.Id">
                                    <i class="bi bi-shield-lock"></i> Права доступу
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
