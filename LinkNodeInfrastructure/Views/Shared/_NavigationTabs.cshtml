@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@inject UserManager<LinkNodeDomain.Model.User> UserManager
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var isFreelancer = User.IsInRole("freelancer");
    var isAdmin = User.IsInRole("admin");

    var currentUser = await UserManager.GetUserAsync(User);
    bool isActive = currentUser?.IsActive ?? true;
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <ul class="nav nav-tabs border-0 align-items-center w-100">
        @if (isAdmin)
        {
            <li class="nav-item">
                <a class="nav-link @(currentController == "Clients" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                   asp-controller="Clients" asp-action="Index">
                    <i class="bi bi-people me-2"></i>Клієнти
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "Freelancers" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                   asp-controller="Freelancers" asp-action="ForAdmin">
                    <i class="bi bi-person-badge me-2"></i>Фрілансери
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "Vacancies" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                   asp-controller="Vacancies" asp-action="Index">
                    <i class="bi bi-briefcase me-2"></i>Вакансії
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentController == "Categories" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                   asp-controller="Categories" asp-action="Index">
                    <i class="bi bi-tags me-2"></i>Категорії
                </a>
            </li>
        }
        else if (isFreelancer)
        {
            @if (isActive)
            {
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Freelancers" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                    asp-controller="Freelancers" asp-action="Details" asp-route-id="@userId">
                        <i class="bi bi-person me-2"></i>Мій профіль
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Vacancies" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                    asp-controller="Vacancies" asp-action="Index">
                        <i class="bi bi-briefcase me-2"></i>Вакансії
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Invites" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                    asp-controller="Invites" asp-action="Index">
                        <i class="bi bi-envelope-paper me-2"></i>Інвайти
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Interviews" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                    asp-controller="Interviews" asp-action="Index">
                        <i class="bi bi-chat-dots me-2"></i>Інтерв'ю
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Proposals" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                    asp-controller="Proposals" asp-action="Index">
                        <i class="bi bi-file-earmark-text me-2"></i>Пропоузали
                    </a>
                </li>
            }
            else
            {
               
                <li class="nav-item">
                    <span class="nav-link text-danger fw-bold">
                        <i class="bi bi-exclamation-octagon me-2"></i>Акаунт заблоковано
                    </span>
                </li>
            }
        }
        else
        {
            @if (isActive)
            {
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Freelancers" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                       asp-controller="Freelancers" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Фрілансери
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Vacancies" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                       asp-controller="Vacancies" asp-action="Index">
                        <i class="bi bi-briefcase me-2"></i>Вакансії
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Interviews" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                       asp-controller="Interviews" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Інтерв'ю
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Invites" ? "active fw-bold border-bottom border-3 border-primary" : "text-muted")"
                       asp-controller="Invites" asp-action="Index">
                        <i class="bi bi-briefcase me-2"></i>Інвайти
                    </a>
                </li>

                <li class="nav-item ms-4 d-flex gap-2">
                    <a asp-controller="Clients" asp-action="Import"
                       class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold shadow-sm transition-hover-blue">
                        <i class="bi bi-file-earmark-arrow-up me-1"></i> Імпорт
                    </a>

                    <a asp-controller="Clients" asp-action="Export"
                       class="btn btn-outline-success btn-sm rounded-pill px-3 fw-bold shadow-sm transition-hover-green">
                        <i class="bi bi-file-earmark-arrow-down me-1"></i> Експорт
                    </a>
                </li>
            }
            else
            {
  
                <li class="nav-item">
                    <span class="nav-link text-danger fw-bold">
                        <i class="bi bi-exclamation-octagon me-2"></i>Акаунт заблоковано
                    </span>
                </li>
            }
        }

        <div class="ms-auto d-flex align-items-center">
            <div class="vr mx-3 text-muted opacity-25" style="height: 24px;"></div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                <button type="submit" class="btn btn-logout-minimal d-flex align-items-center gap-2 text-muted">
                    <span class="small fw-bold">Вийти</span>
                    <i class="bi bi-box-arrow-right fs-5"></i>
                </button>
            </form>
        </div>
    </ul>
</div>

<style>
    .transition-hover-blue,
    .transition-hover-green {
        transition: all 0.3s ease;
    }

        .transition-hover-blue:hover {
            background-color: #0d6efd;
            color: white !important;
            transform: scale(1.05);
        }

        .transition-hover-green:hover {
            background-color: #198754;
            color: white !important;
            transform: scale(1.05);
        }

    
    .btn-logout-minimal {
        border: none;
        background: transparent;
        transition: all 0.2s ease;
        padding: 5px 10px;
        border-radius: 50px;
    }

        .btn-logout-minimal:hover {
            color: #dc3545 !important;
            background-color: rgba(220, 53, 69, 0.05);
            transform: translateY(-1px);
        }
</style>