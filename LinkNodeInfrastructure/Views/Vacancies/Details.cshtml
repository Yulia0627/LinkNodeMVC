@model LinkNodeDomain.Model.Vacancy

@{
    ViewData["Title"] = "Деталі вакансії";
}

<div class="container mt-4">
    <hr />

    <div class="row">
        <div class="col-md-10 offset-md-1">
            <h3 class="mb-3">Пропозиції від фрілансерів (@Model.Proposals.Count)</h3>

            @if (!Model.Proposals.Any())
            {
                <div class="alert alert-light border shadow-sm">
                    На цю вакансію ще ніхто не відгукнувся.
                </div>
            }
            else
            {
                @foreach (var proposal in Model.Proposals)
                {
                    <div class="card mb-3 shadow-sm border-start border-primary border-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="fw-bold mb-0">
                                    <a asp-controller="Freelancers" asp-action="Details" asp-route-id="@proposal.FreelancerId" class="text-decoration-none text-primary">
                                        @proposal.Freelancer?.FreelancerNavigation?.Name
                                    </a>
                                </h5>

                                <div class="d-flex align-items-center">
                                    <span class="text-success fw-bold me-3">$@proposal.Price</span>

                                    <form asp-controller="Interviews" asp-action="Create" method="post" class="d-inline">
                                        <input type="hidden" name="vacancyId" value="@Model.Id" />
                                        <input type="hidden" name="freelancerId" value="@proposal.FreelancerId" />
                                        <a asp-controller="Interviews"
                                           asp-action="Create"
                                           asp-route-proposalId="@proposal.Id"
                                           class="btn btn-outline-success btn-sm fw-bold">
                                            Запросити
                                        </a>
                                    </form>
                                </div>
                            </div>
                            <p class="text-muted mb-0">@proposal.Description</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>