@model LinkNodeDomain.Model.Vacancy

@{
    ViewData["Title"] = "Зміна вакансії";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="mb-0">Редагування вакансії</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ClientId" />

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Назва вакансії</label>
                            <input asp-for="Title" class="form-control" placeholder="Наприклад: .NET Developer" />
                           
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Категорія</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Тип зайнятості</label>
                                <select asp-for="EmpTypeId" class="form-select" asp-items="ViewBag.EmpTypeId"></select>
                                <span asp-validation-for="EmpTypeId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-bold">Погодинна оплата ($)</label>
                            
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                           
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Опис вакансії</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-dark px-4">Зберегти зміни</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}