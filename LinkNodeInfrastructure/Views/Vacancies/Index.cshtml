@model IEnumerable<LinkNodeDomain.Model.Vacancy>

@{
    ViewData["Title"] = "Index";
   
    var currentUserId = 9;
   
    var isClient = (currentUserId !=9);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-0"> Вакансії</h1>
        </div>

       
        @if (isClient)
        {
            <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
                <i class="bi bi-plus-circle"></i> Створити вакансію
            </a>
        }
    </div>

    <div class="card shadow-sm mb-4 bg-white border-0" style="border-radius: 12px;">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Тип зайнятості</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-briefcase"></i></span>
                        <select name="empTypeId" class="form-select bg-light border-0" asp-items="ViewBag.EmpTypeId">
                            <option value="">Оберіть тип зайнятості</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Категорія</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-tag"></i></span>
                        <select name="categoryId" class="form-select bg-light border-0" asp-items="ViewBag.CategoryId">
                            <option value="">Оберіть категорію</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Мін. погодинна ставка(₴)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">₴</span>
                        <input type="number" name="price" value="@ViewData["CurrentPrice"]"
                               class="form-control bg-light border-0" placeholder="Мінімальна ставка..." />
                    </div>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">
                        <i class="bi bi-search me-2"></i> Знайти
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-3 shadow-sm d-flex align-items-center" title="Скинути фільтри">
                        <i class="bi bi-arrow-clockwise me-1"></i> Очистити
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted opacity-25">📁</div>
            <h3 class="text-muted">Наразі немає відкритих вакансій</h3>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 mb-3">
                    <div class="card vacancy-card border-0 shadow-sm @(item.ClosedDate != null ? "opacity-75 bg-light" : "")">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center mb-2">
                                        <h4 class="card-title fw-bold mb-0 me-3">@item.Title</h4>
                                        @if (item.ClosedDate != null)
                                        {
                                            <span class="badge bg-secondary">Закрита</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Активна</span>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <span class="badge rounded-pill bg-outline-primary border border-primary text-primary me-2">
                                            <i class="bi bi-tag"></i> @item.Category?.Category1
                                        </span>
                                        <span class="text-muted small me-3">
                                            <i class="bi bi-briefcase"></i> @item.EmpType?.EmpType
                                        </span>
                                        <span class="text-muted small">
                                            <i class="bi bi-calendar3"></i> @item.CreatedDate.ToString("dd.MM.yyyy")
                                        </span>
                                    </div>

                                    <p class="card-text text-secondary text-truncate-2">
                                        @item.Description
                                    </p>
                                </div>

                                <div class="col-md-4 text-md-end border-start-md">
                                    <div class="mb-3">
                                        
                                        <span class="display-6 fw-bold text-dark">@item.Price.ToString("N0") ₴</span>
                                        <p class="text-muted small mb-0">Бюджет проєкту</p>
                                    </div>

                                    <div class="btn-group w-100 shadow-sm">
                                        
                                        @if (item.ClientId == currentUserId)
                                        {
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info px-4 fw-bold text-white w-75">
                                                <i class="bi bi-eye"></i> Відгуки
                                            </a>

                                            <button type="button" class="btn btn-info dropdown-toggle dropdown-toggle-split text-white border-start border-white border-opacity-25"
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <span class="visually-hidden">Toggle Dropdown</span>
                                            </button>

                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Id">🔧 Редагувати</a></li>
                                                @if (item.ClosedDate == null)
                                                {
                                                    <li>
                                                        <form asp-action="Close" asp-route-id="@item.Id" method="post">
                                                            <button type="submit" class="dropdown-item text-warning py-2">🔒 Закрити</button>
                                                        </form>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                        
                                        else if (item.ClosedDate == null)
                                        {
                                            <a asp-controller="Proposals" asp-action="Create" asp-route-vacancyId="@item.Id"
                                               class="btn btn-primary px-4 fw-bold py-2 w-100">
                                                Відгукнутися
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .vacancy-card {
        transition: box-shadow 0.2s ease-in-out;
        border-left: 5px solid #0d6efd !important;
    }

        .vacancy-card:hover {
            box-shadow: 0 8px 20px rgba(0,0,0,0.12) !important;
        }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .dropdown-menu {
        margin-top: 5px !important;
        border-radius: 8px;
    }

    @@media (min-width: 768px) {
        .border-start-md {
            border-left: 1px solid #dee2e6 !important;
            padding-left: 20px;
        }
    }
</style>