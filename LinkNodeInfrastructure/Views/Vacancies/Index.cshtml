@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@model IEnumerable<LinkNodeDomain.Model.Vacancy>
@inject UserManager<LinkNodeDomain.Model.User> UserManager

@{
    ViewData["Title"] = "Вакансії";

    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int? currentUserId = userIdClaim != null ? int.Parse(userIdClaim) : null;

   
    var isClient = User.IsInRole("client");
    var isFreelancer = User.IsInRole("freelancer"); 
    var currentUser = await UserManager.GetUserAsync(User);
    bool isActive = currentUser?.IsActive ?? true;
}
@await Html.PartialAsync("_NavigationTabs")


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-primary mb-0">Вакансії</h1>

       
        

        @if (isClient & isActive)
        {
            <a asp-action="Create" class="btn btn-success btn-lg shadow-sm px-4">
                <i class="bi bi-plus-circle me-2"></i>Створити вакансію
            </a>
        }
    </div>

    <div class="card shadow-sm mb-4 bg-white border-0" style="border-radius: 12px;">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Тип зайнятості</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-briefcase"></i></span>
                        <select name="empTypeId" class="form-select bg-light border-0" asp-items="ViewBag.EmpTypeId">
                            <option value="">Усі типи</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Категорія</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-tag"></i></span>
                        <select name="categoryId" class="form-select bg-light border-0" asp-items="ViewBag.CategoryId">
                            <option value="">Усі категорії</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Мін. ставка (₴)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">₴</span>
                        <input type="number" name="price" min="0" value="@ViewData["CurrentPrice"]" class="form-control bg-light border-0" placeholder="0" />
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">Знайти</button>
                    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">Очистити</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted opacity-25">📁</div>
            <h3 class="text-muted mt-3">Вакансій не знайдено</h3>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 mb-3">
                  
                    <div class="card vacancy-card border-0 shadow-sm @(item.ClosedDate != null ? "opacity-75 bg-light" : "")">

                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center mb-2">
                                       
                                        <h4 class="card-title fw-bold mb-0 me-3 text-primary"
                                            style="cursor: pointer;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#vacancyModal-@item.Id">
                                            @item.Title
                                        </h4>
                                        <span class="badge @(item.ClosedDate != null ? "bg-secondary" : "bg-success")">
                                            @(item.ClosedDate != null ? "Закрита" : "Активна")
                                        </span>
                                    </div>

                                    <div class="mb-3">
                                        <span class="badge rounded-pill bg-light border text-primary me-2">
                                            <i class="bi bi-tag me-1"></i> @(item.Category?.Category1 ?? "Загальне")
                                        </span>

                                        <span class="badge rounded-pill bg-light border text-success me-2">
                                            <i class="bi bi-clock-history me-1"></i> @(item.EmpType?.EmpType ?? "Не вказано")
                                        </span>

                                        <span class="text-muted small">
                                            <i class="bi bi-calendar3 me-1"></i> @item.CreatedDate.ToString("dd.MM.yyyy")
                                        </span>

                                        
                                        @if (User.IsInRole("FREELANCER"))
                                        {
                                            <div class="mt-2">
                                                <button type="button" ...>
                                                    <i class="bi bi-person-circle me-1 text-primary"></i> Профіль замовника
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    <p class="card-text text-secondary text-truncate-2">@item.Description</p>
                                </div>

                                <div class="col-md-4 text-md-end border-start-md">
                                    @if (item.Price > 0)
                                    {
                                        <div class="mb-3">
                                            <span class="display-6 fw-bold text-dark">@item.Price.ToString("N0") ₴</span>
                                            <p class="text-muted small mb-0">Бюджет проєкту</p>
                                        </div>
                                    }

                                    <div class="btn-group w-100 shadow-sm" onclick="event.stopPropagation();">
                                        @if (item.ClientId == currentUserId)
                                        {
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white w-75 fw-bold">Відгуки</a>
                                            <button type="button" class="btn btn-info text-white dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown"></button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">🔧 Редагувати</a></li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger" onclick="confirmDelete(@item.Id)">
                                                        🗑️ Видалити вакансію
                                                    </button>
                                                </li>
                                                <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                                    @Html.AntiForgeryToken()
                                                </form>
                                            </ul>
                                        }
                                       
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                
                <div class="modal fade" id="vacancyModal-@item.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                            <div class="modal-header bg-primary text-white p-4">
                                <h5 class="modal-title fw-bold">@item.Title</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="row g-3 mb-4">
                                    <div class="col-6 col-md-4">
                                        <div class="p-2 border rounded bg-light text-center">
                                            <small class="text-muted d-block small">КАТЕГОРІЯ</small>
                                            <span class="fw-bold">@(item.Category?.Category1 ?? "Не вказано")</span>
                                        </div>
                                    </div>
                                    <div class="col-6 col-md-4">
                                        <div class="p-2 border rounded bg-light text-center">
                                            <small class="text-muted d-block small">ТИП РОБОТИ</small>
                                            <span class="fw-bold">@(item.EmpType?.EmpType ?? "Не вказано")</span>
                                        </div>
                                    </div>
                                    @if (item.Price > 0)
                                    {
                                        <div class="col-12 col-md-4">
                                            <div class="p-2 border rounded bg-primary bg-opacity-10 text-center">
                                                <small class="text-primary d-block small fw-bold">БЮДЖЕТ</small>
                                                <span class="fw-bold text-primary">@item.Price.ToString("N0") ₴</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <h6 class="fw-bold text-uppercase small text-muted mb-2">Опис завдання:</h6>
                                <div class="bg-white p-3 border rounded-3 mb-3">
                                    <p class="mb-0 text-dark" style="white-space: pre-line; line-height: 1.6;">@item.Description</p>
                                </div>
                                <div class="text-end text-muted small">
                                    <i class="bi bi-clock me-1"></i> Опубліковано: @item.CreatedDate.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                            <div class="modal-footer border-0 p-4 pt-0">
                                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Закрити</button>
                               <a asp-controller="Proposals" 
   asp-action="Create" 
   asp-route-vacancyId="@item.Id" 
   class="btn btn-primary px-4 shadow-sm fw-bold rounded-pill">
    <i class="bi bi-send-fill me-2"></i> Відгукнутися
</a>
                               
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade client-profile-modal" id="clientModal-@item.ClientId" tabindex="-1" aria-hidden="true" data-client-id="@item.ClientId">
                    <div class="modal-dialog modal-md modal-dialog-centered">
                        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                            <div class="modal-header bg-white border-0 pt-4 px-4">
                                <h5 class="modal-title fw-bold text-dark">
                                    <i class="bi bi-person-badge me-2 text-primary"></i>Профіль замовника
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="text-center mb-4">
                                    <div class="avatar-placeholder bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                                        @(string.IsNullOrEmpty(item.Client?.CompanyName) ? "К" : item.Client.CompanyName.Substring(0, 1).ToUpper())
                                    </div>
                                    <h3 class="fw-bold mb-1">@(item.Client?.CompanyName ?? "Клієнт #" + item.ClientId)</h3>
                                    <span class="badge bg-light text-muted border px-3 py-2">
                                        <i class="bi bi-geo-alt me-1"></i> @(item.Client?.ClientNavigation?.Country ?? "Україна")
                                    </span>
                                </div>
                                <div class="row g-3">
                                    <div class="col-6">
                                        <div class="p-3 border rounded-3 bg-light text-center">
                                            <small class="text-muted d-block text-uppercase fw-bold mb-1" style="font-size: 0.65rem;">Відсоток найму</small>
                                            <span class="fs-5 fw-bold text-dark">@(item.Client?.HireRate ?? 0)%</span>
                                            <div class="progress mt-2" style="height: 4px;">
                                                <div class="progress-bar bg-primary" style="width: @(item.Client?.HireRate ?? 0)%"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="p-3 border rounded-3 bg-light text-center">
                                            <small class="text-muted d-block text-uppercase fw-bold mb-1" style="font-size: 0.65rem;">Сер. оплата</small>
                                            <span class="fs-5 fw-bold text-success">₴@(item.Client?.AvgHourlyRatePaid?.ToString("N0") ?? "0")</span>
                                            <small class="text-muted">/ год</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4">
                                    <h6 class="fw-bold text-muted small text-uppercase mb-2"><i class="bi bi-bar-chart-line me-1"></i>Статистика публікацій</h6>
                                    <div id="chart-@item.ClientId" style="width: 100%; height: 200px;">
                                        <div class="text-center p-5">
                                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-info border-0 mt-4 mb-0" style="border-radius: 12px;">
                                    <small><i class="bi bi-info-circle me-2"></i>Зареєстрований з @item.CreatedDate.ToString("yyyy") року.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
        }

    .nav-tabs {
        border-bottom: 2px solid #dee2e6;
    }

        .nav-tabs .nav-link {
            border: none;
            color: #6c757d;
            padding: 10px 20px;
        }

            .nav-tabs .nav-link.active {
                color: #0d6efd !important;
                background: none;
            }
</style>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', {'packages':['corechart']});

        $(document).on('shown.bs.modal', '.client-profile-modal', function () {
            const clientId = $(this).data('client-id');
            const elementId = `chart-${clientId}`;
            drawActivityChart(clientId, elementId);
        });

        function drawActivityChart(clientId, elementId) {
            fetch(`/api/stats/client-jobs-activity?clientId=${clientId}`)
                .then(response => response.json())
                .then(data => {
                    if (!data || data.length === 0) {
                        document.getElementById(elementId).innerHTML = '<p class="text-center text-muted p-4">Дані про активність відсутні</p>';
                        return;
                    }

                    const dataTable = new google.visualization.DataTable();
                    dataTable.addColumn('string', 'Період');
                    dataTable.addColumn('number', 'Вакансії');

                    data.forEach(item => {
                        const label = `${item.month}/${item.year}`;
                        dataTable.addRow([label, item.jobsCount]);
                    });

                    const options = {
                        legend: { position: 'none' },
                        colors: ['#0d6efd'],
                        chartArea: { width: '90%', height: '70%' },
                        hAxis: { textStyle: { fontSize: 10 } },
                        vAxis: { minValue: 0, textStyle: { fontSize: 10 }, gridlines: { count: 4 } },
                        animation: { startup: true, duration: 800, easing: 'out' }
                    };

                    const chart = new google.visualization.ColumnChart(document.getElementById(elementId));
                    chart.draw(dataTable, options);
                })
                .catch(err => {
                    console.error("Chart error:", err);
                    document.getElementById(elementId).innerHTML = '<p class="text-center text-danger p-4">Помилка завантаження графіка</p>';
                });
        }

        function confirmDelete(id) {
            if (confirm("Ви впевнені, що хочете видалити цю вакансію?")) {
                document.getElementById('delete-form-' + id).submit();
            }
        }
    </script>
}